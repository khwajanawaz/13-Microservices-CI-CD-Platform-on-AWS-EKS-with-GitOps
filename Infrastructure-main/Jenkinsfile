pipeline {
    agent any

    parameters {
        choice(
            name: 'terraformAction',
            choices: ['apply', 'destroy'],
            description: 'Choose your terraform action'
        )
    }

    environment {
        AWS_ACCESS_KEY_ID     = credentials('AWS_ACCESS_KEY_ID')
        AWS_SECRET_ACCESS_KEY = credentials('AWS_SECRET_ACCESS_KEY')
        AWS_DEFAULT_REGION    = 'us-east-1'
    }

    stages {

        stage('Check AWS Identity') {
            steps {
                sh '''
                    aws sts get-caller-identity
                    aws configure list || true
                '''
            }
        }

        stage('Plan: 0-bootstrap') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                sh '''
                    cd Infrastructure-main/0-bootstrap
                    terraform init -input=false
                    terraform import aws_s3_bucket.tf_state quantamvector-infra-statefile-backup || true
                    terraform import aws_dynamodb_table.tf_lock quantamvector-terraform-locks || true
                    terraform plan -out tfplan
                    terraform show -no-color tfplan > tfplan.txt
                '''
            }
        }

        stage('Approval: 0-bootstrap') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                script {
                    def plan = readFile 'Infrastructure-main/0-bootstrap/tfplan.txt'
                    input message: '[0-bootstrap] Approve to proceed',
                          parameters: [text(name: 'Plan', description: 'Terraform Plan Output', defaultValue: plan)]
                }
            }
        }

        stage('Apply: 0-bootstrap') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                sh '''
                    cd Infrastructure-main/0-bootstrap
                    terraform apply -input=false tfplan
                '''
            }
        }

        stage('Plan: 1-network') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                sh '''
                    cd Infrastructure-main/1-network
                    terraform init -reconfigure -input=false
                    terraform plan -out tfplan
                    terraform show -no-color tfplan > tfplan.txt
                '''
            }
        }

        stage('Approval: 1-network') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                script {
                    def plan = readFile 'Infrastructure-main/1-network/tfplan.txt'
                    input message: '[1-network] Approve to proceed',
                          parameters: [text(name: 'Plan', description: 'Terraform Plan Output', defaultValue: plan)]
                }
            }
        }

        stage('Apply: 1-network') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                sh '''
                    cd Infrastructure-main/1-network
                    terraform apply -input=false tfplan
                '''
            }
        }

        stage('Plan: 2-eks') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                sh '''
                    cd Infrastructure-main/2-eks
                    terraform init -reconfigure -input=false
                    terraform plan -out tfplan
                    terraform show -no-color tfplan > tfplan.txt
                '''
            }
        }

        stage('Approval: 2-eks') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                script {
                    def plan = readFile 'Infrastructure-main/2-eks/tfplan.txt'
                    input message: '[2-eks] Approve to proceed',
                          parameters: [text(name: 'Plan', description: 'Terraform Plan Output', defaultValue: plan)]
                }
            }
        }

        stage('Apply: 2-eks') {
            when { expression { params.terraformAction == 'apply' } }
            steps {
                sh '''
                    cd Infrastructure-main/2-eks
                    terraform apply -input=false tfplan
                '''
            }
        }

        stage('Destroy: 2-eks') {
            when { expression { params.terraformAction == 'destroy' } }
            steps {
                sh '''
                    cd Infrastructure-main/2-eks
                    terraform init -reconfigure -input=false || echo "terraform init failed in 2-eks, continuing"
                    terraform destroy -auto-approve -lock=false || echo "terraform destroy failed or nothing left in 2-eks"
                '''
            }
        }

        stage('Delete NAT Gateway') {
            when { expression { params.terraformAction == 'destroy' } }
            steps {
                sh '''
                    echo "Checking NAT Gateways in ${AWS_DEFAULT_REGION} ..."
                    aws ec2 describe-nat-gateways \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'NatGateways[*].[NatGatewayId,State,VpcId]' \
                      --output table || true

                    for nat in $(aws ec2 describe-nat-gateways \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'NatGateways[?State!=`deleted`].NatGatewayId' \
                      --output text); do
                        echo "Deleting NAT Gateway: $nat"
                        aws ec2 delete-nat-gateway --nat-gateway-id "$nat" --region ${AWS_DEFAULT_REGION} || true
                    done
                '''
            }
        }

        stage('Check NAT Gateway After Delete') {
            when { expression { params.terraformAction == 'destroy' } }
            steps {
                sh '''
                    echo "NAT Gateway status after delete request:"
                    aws ec2 describe-nat-gateways \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'NatGateways[*].[NatGatewayId,State,VpcId]' \
                      --output table || true
                '''
            }
        }

        stage('Destroy: 1-network') {
            when { expression { params.terraformAction == 'destroy' } }
            steps {
                sh '''
                    cd Infrastructure-main/1-network
                    terraform init -reconfigure -input=false || echo "terraform init failed in 1-network, continuing"
                    terraform destroy -auto-approve -lock=false || echo "terraform destroy failed or nothing left in 1-network"
                '''
            }
        }

        stage('Destroy: 0-bootstrap') {
            when { expression { params.terraformAction == 'destroy' } }
            steps {
                sh '''
                    cd Infrastructure-main/0-bootstrap
                    terraform init -input=false || echo "terraform init failed in 0-bootstrap, continuing"
                    terraform destroy -auto-approve -lock=false || echo "terraform destroy failed or nothing left in 0-bootstrap"
                '''
            }
        }

        stage('Final AWS Check') {
            when { expression { params.terraformAction == 'destroy' } }
            steps {
                sh '''
                    echo "=== EKS Clusters ==="
                    aws eks list-clusters --region ${AWS_DEFAULT_REGION} || true

                    echo "=== NAT Gateways ==="
                    aws ec2 describe-nat-gateways \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'NatGateways[*].[NatGatewayId,State,VpcId]' \
                      --output table || true

                    echo "=== VPCs ==="
                    aws ec2 describe-vpcs \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'Vpcs[*].[VpcId,IsDefault,CidrBlock,State]' \
                      --output table || true

                    echo "=== Subnets ==="
                    aws ec2 describe-subnets \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'Subnets[*].[SubnetId,VpcId,CidrBlock,AvailabilityZone]' \
                      --output table || true

                    echo "=== Internet Gateways ==="
                    aws ec2 describe-internet-gateways \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'InternetGateways[*].[InternetGatewayId,Attachments]' \
                      --output table || true

                    echo "=== Security Groups ==="
                    aws ec2 describe-security-groups \
                      --region ${AWS_DEFAULT_REGION} \
                      --query 'SecurityGroups[*].[GroupId,GroupName,VpcId]' \
                      --output table || true
                '''
            }
        }
    }

    post {
        success {
            echo "terraform ${params.terraformAction} completed successfully."
        }
        failure {
            echo "Pipeline failed. Check the stage logs above."
        }
        always {
            echo "Pipeline finished."
        }
    }
}
